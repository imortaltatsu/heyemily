# Vite dashboard (platform/web) — copy to .env.local for local overrides
# cp .env.example .env.local

# Reown (WalletConnect) — https://cloud.reown.com — only for the "WalletConnect" sign-in button
VITE_WALLETCONNECT_PROJECT_ID=

# Shown in "Copy shell command" after Start when the API is not on 127.0.0.1:8000
# (Vite proxies /api and WS to vite.config.ts target by default)
# VITE_HFT_API_BASE=http://127.0.0.1:8000
