# =============================================================================
# Hyperliquid trading bot + HFT platform (FastAPI dashboard + lite worker)
# Copy: cp .env.example .env   then fill secrets (never commit .env)
# =============================================================================

# -----------------------------------------------------------------------------
# HFT platform API (src/hft_platform — uv run uvicorn hft_platform.main:app)
# -----------------------------------------------------------------------------
# SQLite DB (default is repo-root data/hft_platform.db if unset)
# DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/data/hft_platform.db

# JWT for dashboard login + worker bootstrap (use a long random string in prod)
# JWT_SECRET=change-me-in-production-use-long-random-string

# Fernet key for one custodial HL key per account (openssl rand -base64 32)
# MASTER_ENCRYPTION_KEY=

# Browser origins allowed to call the API (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# When true, dashboard Start spawns run_lite_worker on this host (dev). Set false if workers run elsewhere.
# SPAWN_LOCAL_LITE_WORKER=true

# -----------------------------------------------------------------------------
# Lite worker — platform bootstrap (shell after Start) or local YAML
# -----------------------------------------------------------------------------
# HFT_API_BASE=http://127.0.0.1:8000
# HFT_SESSION_ID=<uuid from dashboard>
# HFT_WORKER_TOKEN=<worker JWT from Start>

# Local-only worker (no platform): same key as HL account
# LITEBOT_PRIVATE_KEY=0x...

# Default on-disk preset matches interval-buy (~1 market buy/s, testnet BTC):
#   uv run python src/run_lite_worker.py --config bots/lite_1_buy_per_sec.yaml
# Session JSON from the dashboard overrides this when using HFT_* bootstrap.

# -----------------------------------------------------------------------------
# Legacy / full grid bot (src/run_bot.py, endpoint router, etc.)
# -----------------------------------------------------------------------------
# HYPERLIQUID_TESTNET_PRIVATE_KEY=0x...
# HYPERLIQUID_MAINNET_PRIVATE_KEY=0x...
# HYPERLIQUID_TESTNET=true
# TESTNET_WALLET_ADDRESS=0x...

# HYPERLIQUID_TESTNET_PUBLIC_BASE_URL=https://api.hyperliquid-testnet.xyz
# HYPERLIQUID_TESTNET_PUBLIC_INFO_URL=https://api.hyperliquid-testnet.xyz/info
# HYPERLIQUID_TESTNET_PUBLIC_EXCHANGE_URL=https://api.hyperliquid-testnet.xyz/exchange
# HYPERLIQUID_TESTNET_PUBLIC_WS_URL=wss://api.hyperliquid-testnet.xyz/ws

# ENDPOINT_HEALTH_CHECK_INTERVAL=300
# ENDPOINT_HEALTH_CHECK_TIMEOUT=10
# LOG_LEVEL=INFO
